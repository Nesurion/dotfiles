# Example private environment variables template
# Copy this to .zshrc.local and fill in your actual values

# Jira
export JIRA_API_TOKEN="your-jira-api-token"

# Ansible
ANSIBLE_VAULT_PASSWORD_FILE=~/.ansible-leanix-vault-pass.txt

# Teams meeting link (optional)
alias teams="open 'https://teams.microsoft.com/l/meetup-join/YOUR_MEETING_LINK_HERE'"
