[core]
  pager = delta

[diff]
  colorMoved = default

[interactive]
  diffFilter = delta --color-only --features=interactive

[delta]
  line-numbers = true
	side-by-side = false
	syntax-theme = tokyonight_moon
  features = zebra-dark
  map-styles = bold purple => syntax "#2d1b4e", bold cyan => syntax "#0d3344"

[delta "interactive"]
  keep-plus-minus-markers = false

[alias]
  prune-branches = !git branch --merged origin/master | grep -vw master | xargs git branch -d

[user]
	email = maik.schwan@leanix.net
	name = Maik Schwan
[init]
	templatedir = ~/.git_template
[push]
	autoSetupRemote = true

[includeIf "gitdir:~/dev-private/"]
  path = ~/.gitconfig-private

[includeIf "gitdir:~/dev-sap/"]
  path = ~/.gitconfig-sap

[diff "ansible-vault"]
	textconv = ansible-vault view

[pull]
	rebase = true
